# Supabase browser and server session configuration
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only Supabase administration key. Never expose this to browser code.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only Anthropic API key for HQ AI council. Never expose this to browser code.
ANTHROPIC_API_KEY=

# Direct PostgreSQL connection used by migrations, seeds, and server repositories.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Local loopback development only. Production code always ignores this fallback.
ACADEMY_LOCAL_BOOTSTRAP_ENABLED=false

# Optional demo feedback experience
DEMO_MODE_ENABLED=false
NEXT_PUBLIC_DEMO_MODE_ENABLED=false
NEXT_PUBLIC_DEMO_VERSION=local

# Optional external LMS launch configuration
MOODLE_LAUNCH_BASE_URL=
MOODLE_LAUNCH_MODE=
CANVAS_LAUNCH_BASE_URL=
CANVAS_LAUNCH_MODE=
